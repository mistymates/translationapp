TRANSCRIBE_PROVIDER=deepgram
DEEPGRAM_API_KEY=your_deepgram_key_here
OPENAI_API_KEY=
OPENAI_BASE_URL=
PORT=3000
UI_TEST_MODE=0

# VAD tuning
VAD_FRAME_MS=30
VAD_AGGRESSIVENESS=3
VAD_MIN_SPEECH_MS=250
VAD_HANGOVER_MS=300
VAD_MAX_SEGMENT_MS=4500
DISABLE_VAD=false
RAW_SEGMENT_MS=4200
TAGALOG_RETRY_ENABLED=true

# Models
TRANSCRIBE_MODEL=nova-3
DEEPGRAM_LANGUAGE=multi
DEEPGRAM_DETECT_LANGUAGE=true
TRANSLATE_MODEL=gpt-4o-mini
TRANSLATE_ALLOWED_LANGS=fr,es,tl,zh,km
TRANSLATE_SKIP_ENGLISH=true
TRANSLATE_FALLBACK_ENABLED=true

